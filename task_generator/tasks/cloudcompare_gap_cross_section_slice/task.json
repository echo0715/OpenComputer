{
  "id": "cloudcompare_gap_cross_section_slice",
  "app": "cloudcompare",
  "task": "/home/user/Documents/tower.ply is an ASCII PLY with 2000 points distributed in a vertical column (X, Y in -1..1, Z in 0..10).\n\nExtract a thin horizontal slice keeping only points with Z in the interval [4.5, 5.5], and export the slice cloud as an ASCII PLY at /home/user/Documents/tower_slice.ply. The output must have at least 50 points (and strictly fewer than the original 2000), and every point's Z coordinate must lie within [4.5, 5.5].",
  "env": {
    "files": [
      {
        "filename": "tower.ply",
        "sandbox_path": "/home/user/Documents/tower.ply"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/tower_slice.ply",
      "key": "exists",
      "expected": true,
      "description": "Slice exists"
    },
    {
      "command": "check-bbox-within /home/user/Documents/tower_slice.ply -2 -2 4.5 2 2 5.5",
      "key": "match",
      "expected": true,
      "description": "All points within Z in [4.5, 5.5]"
    },
    {
      "command": "check-point-count-at-least /home/user/Documents/tower_slice.ply 50",
      "key": "match",
      "expected": true,
      "description": "At least 50 points remain"
    },
    {
      "command": "cloud-info /home/user/Documents/tower_slice.ply",
      "eval": "result.get('vertex_count', 2000) < 2000",
      "description": "Strictly fewer points than original"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "estimated_difficulty": 4
  }
}
