{
  "id": "vlc_play_video_file",
  "app": "vlc",
  "task": "VLC is already running. Open /home/user/Videos/sample.mp4 and begin playback. Leave the file actively playing when done; do not pause, stop, or close VLC.",
  "env": {
    "files": [
      {
        "filename": "sample.mp4",
        "sandbox_path": "/home/user/Videos/sample.mp4"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Videos/sample.mp4",
      "key": "exists",
      "expected": true,
      "description": "Source sample.mp4 exists"
    },
    {
      "command": "check-media-loaded sample.mp4",
      "key": "loaded",
      "expected": true,
      "description": "sample.mp4 is loaded in VLC"
    },
    {
      "command": "check-playing",
      "key": "playing",
      "expected": true,
      "description": "VLC is currently playing"
    }
  ],
  "metadata": {
    "complexity": 3,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 3
  }
}
