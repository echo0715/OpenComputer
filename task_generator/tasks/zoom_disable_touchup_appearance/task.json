{
  "id": "zoom_disable_touchup_appearance",
  "app": "zoom",
  "task": "A baseline Zoom config file exists at /home/user/.config/zoomus.conf with `[Video]TouchUpMyAppearance=true`.\n\nSet `[Video]TouchUpMyAppearance` to `false` so the 'Touch up my appearance' filter is disabled. Save the file in-place at /home/user/.config/zoomus.conf. Do not modify any other keys (leave `[Video]mirrorMyVideo` untouched).",
  "env": {
    "files": [
      {
        "filename": "zoomus.conf",
        "sandbox_path": "/home/user/.config/zoomus.conf"
      }
    ]
  },
  "verification": [
    {
      "command": "check-config-exists",
      "key": "exists",
      "expected": true,
      "description": "zoomus.conf exists"
    },
    {
      "command": "check-config Video TouchUpMyAppearance false",
      "key": "match",
      "expected": true,
      "description": "[Video]TouchUpMyAppearance == false"
    },
    {
      "command": "check-config Video mirrorMyVideo true",
      "key": "match",
      "expected": true,
      "description": "mirrorMyVideo left untouched"
    }
  ],
  "metadata": {
    "complexity": 3,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 3
  }
}
