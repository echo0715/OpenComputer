{
  "id": "cloudcompare_ply_mesh_to_obj",
  "app": "cloudcompare",
  "task": "/home/user/Documents/tetra.ply is an ASCII PLY tetrahedron mesh with 4 vertices and 4 triangular faces.\n\nSave the mesh as an OBJ file at /home/user/Documents/tetra.obj, preserving all 4 vertices and all 4 triangular faces (export the mesh, not a vertices-only cloud).",
  "env": {
    "files": [
      {
        "filename": "tetra.ply",
        "sandbox_path": "/home/user/Documents/tetra.ply"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/tetra.obj",
      "key": "exists",
      "expected": true,
      "description": "OBJ output exists"
    },
    {
      "command": "check-is-mesh /home/user/Documents/tetra.obj",
      "key": "is_mesh",
      "expected": true,
      "description": "Output OBJ contains faces"
    },
    {
      "command": "check-point-count /home/user/Documents/tetra.obj 4",
      "key": "match",
      "expected": true,
      "description": "Output has 4 vertices"
    },
    {
      "command": "check-face-count /home/user/Documents/tetra.obj 4",
      "key": "match",
      "expected": true,
      "description": "Output has 4 triangular faces"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
