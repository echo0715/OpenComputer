{
  "id": "godot4_create_standard_material_resource",
  "app": "godot4",
  "task": "Edit /home/user/godot_projects/material_game/materials/red_material.tres. It is already a StandardMaterial3D resource with default placeholder values. Modify its [resource] section so that albedo_color = Color(1, 0, 0, 1) and metallic = 0.5. Leave the file's gd_resource type set to StandardMaterial3D. Save the file.",
  "env": {
    "files": [
      {
