{
  "id": "pcmanfm_dedupe_and_consolidate",
  "app": "pcmanfm",
  "task": "Consolidate the duplicates in /home/user/Documents/downloads/. (1) Delete every file whose name contains a duplicate marker: '(1)', '(2)', or '(copy)'. Keep only the originals: report.txt, notes.txt, summary.txt, invoice.pdf. (2) Create a new sub-directory /home/user/Documents/downloads/invoices/ and MOVE invoice.pdf into it. After all operations, /home/user/Documents/downloads/ must contain exactly 4 top-level entries: report.txt, notes.txt, summary.txt, and the invoices directory. The invoices/ directory must contain exactly 1 file: invoice.pdf.",
  "env": {
    "files": [
      {"filename": "report.txt", "sandbox_path": "/home/user/Documents/downloads/report.txt"},
      {"filename": "report (1).txt", "sandbox_path": "/home/user/Documents/downloads/report (1).txt"},
      {"filename": "report (2).txt", "sandbox_path": "/home/user/Documents/downloads/report (2).txt"},
      {"filename": "notes.txt", "sandbox_path": "/home/user/Documents/downloads/notes.txt"},
      {"filename": "notes (copy).txt", "sandbox_path": "/home/user/Documents/downloads/notes (copy).txt"},
      {"filename": "summary.txt", "sandbox_path": "/home/user/Documents/downloads/summary.txt"},
      {"filename": "summary (1).txt", "sandbox_path": "/home/user/Documents/downloads/summary (1).txt"},
      {"filename": "invoice.pdf", "sandbox_path": "/home/user/Documents/downloads/invoice.pdf"},
      {"filename": "invoice (1).pdf", "sandbox_path": "/home/user/Documents/downloads/invoice (1).pdf"},
      {"filename": "invoice (copy).pdf", "sandbox_path": "/home/user/Documents/downloads/invoice (copy).pdf"}
    ]
  },
  "verification": [
    {"command": "check-file-count /home/user/Documents/downloads 4", "key": "match", "expected": true, "description": "downloads has exactly 4 top-level entries"},
    {"command": "check-dir-exists /home/user/Documents/downloads/invoices", "key": "exists", "expected": true, "description": "invoices subdirectory exists"},
    {"command": "check-file-count /home/user/Documents/downloads/invoices 1", "key": "match", "expected": true, "description": "invoices contains exactly 1 file"},
    {"command": "check-file-exists /home/user/Documents/downloads/report.txt", "key": "exists", "expected": true, "description": "report.txt kept"},
    {"command": "check-file-exists /home/user/Documents/downloads/notes.txt", "key": "exists", "expected": true, "description": "notes.txt kept"},
    {"command": "check-file-exists /home/user/Documents/downloads/summary.txt", "key": "exists", "expected": true, "description": "summary.txt kept"},
    {"command": "check-file-exists /home/user/Documents/downloads/invoices/invoice.pdf", "key": "exists", "expected": true, "description": "invoice.pdf inside invoices/"}
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
