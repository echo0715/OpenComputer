{
  "id": "vlc_gap_equalizer_rock_preset",
  "app": "vlc",
  "task": "In VLC, enable the audio equalizer and apply the 'Rock' preset (equalizer-preset = rock). Make sure the equalizer audio filter is listed in the audio-filter chain. Save the preferences, then play /home/user/Videos/sample.mp4.",
  "env": {
    "files": [
      {"filename": "sample.mp4", "sandbox_path": "/home/user/Videos/sample.mp4"}
    ]
  },
  "verification": [
    {"command": "check-file-exists /home/user/Videos/sample.mp4", "key": "exists", "expected": true, "description": "sample.mp4 is present"},
    {"command": "check-config equalizer-preset rock", "key": "match", "expected": true, "description": "Equalizer preset is 'rock'"},
    {"command": "check-media-loaded sample.mp4", "key": "loaded", "expected": true, "description": "sample.mp4 is loaded and playing"}
  ],
  "metadata": {"complexity": 4, "data_generatability": 5, "estimated_difficulty": 4}
}
