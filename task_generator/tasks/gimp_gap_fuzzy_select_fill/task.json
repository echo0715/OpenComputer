{
  "id": "gimp_gap_fuzzy_select_fill",
  "app": "gimp",
  "task": "Open /home/user/Documents/red_square_on_white.png in GIMP.\n\nReplace the red square region with solid pure green (#00FF00, RGB 0,255,0) while leaving the white background untouched. Export the result as PNG to /home/user/Documents/fuzzy_filled.png. The output must remain 400x400 pixels.",
  "env": {
    "files": [
      {
        "filename": "red_square_on_white.png",
        "sandbox_path": "/home/user/Documents/red_square_on_white.png"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/fuzzy_filled.png",
      "key": "exists",
      "expected": true,
      "description": "Output PNG exists"
    },
    {
      "command": "check-file-dimensions /home/user/Documents/fuzzy_filled.png 400 400",
      "key": "match",
      "expected": true,
      "description": "Output is 400x400"
    },
    {
      "command": "check-pixel-color-file /home/user/Documents/fuzzy_filled.png 200 200 0 255 0 10",
      "key": "match",
      "expected": true,
      "description": "Center of former red square is now green"
    },
    {
      "command": "check-pixel-color-file /home/user/Documents/fuzzy_filled.png 50 50 255 255 255 10",
      "key": "match",
      "expected": true,
      "description": "Background top-left remains white"
    },
    {
      "command": "check-pixel-color-file /home/user/Documents/fuzzy_filled.png 350 350 255 255 255 10",
      "key": "match",
      "expected": true,
      "description": "Background bottom-right remains white"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "estimated_difficulty": 4
  }
}
