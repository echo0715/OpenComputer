{
  "id": "krita_add_filter_mask_blur",
  "app": "krita",
  "task": "Krita is open with /home/user/Documents/scene.kra loaded — two paint layers named 'Background' and 'Overlay'.\n\nAdd a Gaussian Blur filter mask (any reasonable blur radius) as a child of the 'Background' layer, named exactly 'SoftBlur'. Leave the 'Overlay' layer untouched.\n\nSave the file in place at /home/user/Documents/scene.kra.",
  "env": {
    "files": [
      {
        "filename": "scene.kra",
        "sandbox_path": "/home/user/Documents/scene.kra"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/scene.kra",
      "key": "exists",
      "expected": true,
      "description": "scene.kra still exists"
    },
    {
      "command": "check-layer-exists /home/user/Documents/scene.kra Background",
      "key": "exists",
      "expected": true,
      "description": "Background layer preserved"
    },
    {
      "command": "check-layer-exists /home/user/Documents/scene.kra Overlay",
      "key": "exists",
      "expected": true,
      "description": "Overlay layer preserved"
    },
    {
      "command": "check-mask-of /home/user/Documents/scene.kra Background SoftBlur",
      "key": "exists",
      "expected": true,
      "description": "SoftBlur mask is a child of Background"
    },
    {
      "command": "check-layer-node-type /home/user/Documents/scene.kra SoftBlur filtermask",
      "key": "match",
      "expected": true,
      "description": "SoftBlur node type is filtermask"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "estimated_difficulty": 4
  }
}
