      "expected": true,
      "description": "Icon type is Sprite2D"
    },
    {
      "command": "check-node-exists /home/user/godot_projects/build_scene_game/main.tscn Title",
      "key": "exists",
      "expected": true,
      "description": "Title node exists"
    },
    {
      "command": "check-node-type /home/user/godot_projects/build_scene_game/main.tscn Title Label",
