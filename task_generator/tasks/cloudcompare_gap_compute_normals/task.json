{
  "id": "cloudcompare_gap_compute_normals",
  "app": "cloudcompare",
  "task": "/home/user/Documents/surface.ply is an ASCII PLY with 1500 points on a curved paraboloid surface with no per-point normals.\n\nCompute per-point normals (default options are fine), then export the cloud — including the computed normals — as an ASCII PLY at /home/user/Documents/surface_normals.ply. The output must have 1500 points and include nx, ny, nz properties.",
  "env": {
    "files": [
      {
        "filename": "surface.ply",
        "sandbox_path": "/home/user/Documents/surface.ply"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/surface_normals.ply",
      "key": "exists",
      "expected": true,
      "description": "Output exists"
    },
    {
      "command": "check-point-count /home/user/Documents/surface_normals.ply 1500",
      "key": "match",
      "expected": true,
      "description": "1500 points"
    },
    {
      "command": "check-has-normals /home/user/Documents/surface_normals.ply",
      "key": "has_normals",
      "expected": true,
      "description": "Normals present in output"
    },
    {
      "command": "check-ply-format /home/user/Documents/surface_normals.ply ascii",
      "key": "match",
      "expected": true,
      "description": "ASCII PLY"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "estimated_difficulty": 4
  }
}
