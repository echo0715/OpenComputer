{
  "id": "vlc_convert_wav_from_mp3_source",
  "app": "vlc",
  "task": "VLC is already running. Convert the MP3 file /home/user/Music/source_audio.mp3 into an uncompressed WAV file at /home/user/Music/converted.wav using an audio-only WAV profile (WAV encapsulation, PCM audio codec, no video).\n\nThe resulting /home/user/Music/converted.wav must be a valid WAV audio file containing an audio stream and NO video stream.",
  "env": {
    "files": [
      {
        "filename": "source_audio.mp3",
        "sandbox_path": "/home/user/Music/source_audio.mp3"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Music/source_audio.mp3",
      "key": "exists",
      "expected": true,
      "description": "Source source_audio.mp3 exists"
    },
    {
      "command": "check-file-exists /home/user/Music/converted.wav",
      "key": "exists",
      "expected": true,
      "description": "Converted converted.wav exists"
    },
    {
      "command": "check-media-format /home/user/Music/converted.wav wav",
      "key": "match",
      "expected": true,
      "description": "converted.wav is a WAV file"
    },
    {
      "command": "check-media-has-audio /home/user/Music/converted.wav",
      "key": "has_audio",
      "expected": true,
      "description": "converted.wav has an audio stream"
    },
    {
      "command": "check-media-has-video /home/user/Music/converted.wav",
      "key": "has_video",
      "expected": false,
      "description": "converted.wav has NO video stream"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
