{
  "id": "zoom_disable_mirror_video",
  "app": "zoom",
  "task": "A baseline Zoom config file exists at /home/user/.config/zoomus.conf with `[Video]mirrorMyVideo=true`.\n\nSet `[Video]mirrorMyVideo` to `false` to disable the mirror effect on the video preview. Save the file in-place at /home/user/.config/zoomus.conf. Do not modify any other keys (leave `[Video]HDVideo` untouched).",
  "env": {
    "files": [
      {
        "filename": "zoomus.conf",
        "sandbox_path": "/home/user/.config/zoomus.conf"
      }
    ]
  },
  "verification": [
    {
      "command": "check-config-exists",
      "key": "exists",
      "expected": true,
      "description": "zoomus.conf exists"
    },
    {
      "command": "check-config Video mirrorMyVideo false",
      "key": "match",
      "expected": true,
      "description": "[Video]mirrorMyVideo == false"
    },
    {
      "command": "check-config Video HDVideo false",
      "key": "match",
      "expected": true,
      "description": "HDVideo left untouched"
    }
  ],
  "metadata": {
    "complexity": 3,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 3
  }
}
