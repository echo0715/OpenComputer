{
  "id": "cloudcompare_preserve_intensity_export",
  "app": "cloudcompare",
  "task": "/home/user/Documents/lidar_intensity.xyz is a 4-column ASCII point cloud (X Y Z Intensity) with 600 points; the 4th column should be imported as a scalar field (e.g., 'Scalar field #1' or 'intensity').\n\nRe-export the cloud twice, preserving the intensity scalar in both outputs:\n1. ASCII cloud at /home/user/Documents/lidar_intensity.asc with 4 columns enabled (X, Y, Z, intensity scalar).\n2. PLY (ASCII or binary) at /home/user/Documents/lidar_intensity_out.ply with the intensity scalar exported as a scalar/intensity property.\n\nBoth outputs must contain all 600 points.",
  "env": {
    "files": [
      {
        "filename": "lidar_intensity.xyz",
        "sandbox_path": "/home/user/Documents/lidar_intensity.xyz"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/lidar_intensity.asc",
      "key": "exists",
      "expected": true,
      "description": "ASC output exists"
    },
    {
      "command": "check-point-count /home/user/Documents/lidar_intensity.asc 600",
      "key": "match",
      "expected": true,
      "description": "ASC has 600 points"
    },
    {
      "command": "check-has-intensity /home/user/Documents/lidar_intensity.asc",
      "key": "has_intensity",
      "expected": true,
      "description": "ASC preserves intensity scalar (4 columns)"
    },
    {
      "command": "check-file-exists /home/user/Documents/lidar_intensity_out.ply",
      "key": "exists",
      "expected": true,
      "description": "PLY output exists"
    },
    {
      "command": "check-point-count /home/user/Documents/lidar_intensity_out.ply 600",
      "key": "match",
      "expected": true,
      "description": "PLY has 600 points"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 4,
    "estimated_difficulty": 4
  }
}
