{
  "id": "zoom_language_chinese_and_recording",
  "app": "zoom",
  "task": "A baseline Zoom config file exists at /home/user/.config/zoomus.conf. Localize Zoom to Simplified Chinese and relocate local recordings:\n1. Set `[General]language` from `en-US` to `zh-CN`.\n2. Set `[General]localRecordingPath` to exactly `/home/user/Videos/ZoomCN`.\n3. Ensure the directory `/home/user/Videos/ZoomCN` exists on disk.\n\nSave the config file in-place at /home/user/.config/zoomus.conf. Do not modify any other config keys (leave `[General]autoMuteMic` untouched).",
  "env": {
    "files": [
      {
        "filename": "zoomus.conf",
        "sandbox_path": "/home/user/.config/zoomus.conf"
      }
    ]
  },
  "verification": [
    {
      "command": "check-config-exists",
      "key": "exists",
      "expected": true,
      "description": "zoomus.conf exists"
    },
    {
      "command": "check-language zh-CN",
      "key": "match",
      "expected": true,
      "description": "UI language is zh-CN"
    },
    {
      "command": "check-config General language zh-CN",
      "key": "match",
      "expected": true,
      "description": "[General]language == zh-CN"
    },
    {
      "command": "check-recording-path /home/user/Videos/ZoomCN",
      "key": "match",
      "expected": true,
      "description": "Recording path is /home/user/Videos/ZoomCN"
    },
    {
      "command": "check-config General localRecordingPath /home/user/Videos/ZoomCN",
      "key": "match",
      "expected": true,
      "description": "[General]localRecordingPath matches"
    },
    {
      "command": "check-directory-exists /home/user/Videos/ZoomCN",
      "key": "exists",
      "expected": true,
      "description": "Recording directory exists"
    },
    {
      "command": "check-config General autoMuteMic false",
      "key": "match",
      "expected": true,
      "description": "autoMuteMic untouched"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
