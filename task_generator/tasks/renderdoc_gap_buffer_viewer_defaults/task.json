{
  "id": "renderdoc_gap_buffer_viewer_defaults",
  "app": "renderdoc",
  "task": "Configure the Buffer Formatter / Buffer Viewer defaults in /home/user/.local/share/qrenderdoc/UI.config (a flat JSON document) so vertex-data inspection uses a fixed 32-byte stride with hex display. Apply all of the following edits in a single save:\n\n1. Set `\"BufferFormatter_ShowHex\"` to `true`.\n2. Set `\"BufferFormatter_FixedStride\"` to the integer `32`.\n3. Set `\"BufferFormatter_ShowByteRange\"` to `true`.\n\nThe top-level `\"rdocConfigData\": 1` marker must still be present after saving. Do not remove or rename any other key.",
  "env": {
    "files": [
      {
        "filename": "UI.config",
        "sandbox_path": "/home/user/.local/share/qrenderdoc/UI.config"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/.local/share/qrenderdoc/UI.config",
      "key": "exists",
      "expected": true,
      "description": "UI.config still exists"
    },
    {
      "command": "check-setting rdocConfigData 1",
      "key": "match",
      "expected": true,
      "description": "rdocConfigData marker preserved"
    },
    {
      "command": "check-setting BufferFormatter_ShowHex true",
      "key": "match",
      "expected": true,
      "description": "ShowHex is true"
    },
    {
      "command": "check-setting BufferFormatter_FixedStride 32",
      "key": "match",
      "expected": true,
      "description": "FixedStride is 32"
    },
    {
      "command": "check-setting BufferFormatter_ShowByteRange true",
      "key": "match",
      "expected": true,
      "description": "ShowByteRange is true"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
