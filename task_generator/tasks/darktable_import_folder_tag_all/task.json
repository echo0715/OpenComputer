{
  "id": "darktable_import_folder_tag_all",
  "app": "darktable",
  "task": "Import the entire folder /home/user/Pictures/vacation/ (which contains beach.png, forest.png, and lake.png) into the darktable library.\n\nApply the tag 'vacation_2024' to all three imported images, and set every image's star rating to 3 stars.",
  "env": {
    "files": [
      {
        "filename": "beach.png",
        "sandbox_path": "/home/user/Pictures/vacation/beach.png"
      },
      {
        "filename": "forest.png",
        "sandbox_path": "/home/user/Pictures/vacation/forest.png"
      },
      {
        "filename": "lake.png",
        "sandbox_path": "/home/user/Pictures/vacation/lake.png"
      }
    ]
  },
  "verification": [
    {
      "command": "check-image-imported beach.png",
      "key": "imported",
      "expected": true,
      "description": "beach.png is imported into darktable library"
    },
    {
      "command": "check-image-imported forest.png",
      "key": "imported",
      "expected": true,
      "description": "forest.png is imported into darktable library"
    },
    {
      "command": "check-image-imported lake.png",
      "key": "imported",
      "expected": true,
      "description": "lake.png is imported into darktable library"
    },
    {
      "command": "check-tag-exists vacation_2024",
      "key": "exists",
      "expected": true,
      "description": "Tag 'vacation_2024' exists in the library"
    },
    {
      "command": "check-image-tagged 1 vacation_2024",
      "key": "tagged",
      "expected": true,
      "description": "First image is tagged with 'vacation_2024'"
    },
    {
      "command": "check-image-tagged 2 vacation_2024",
      "key": "tagged",
      "expected": true,
      "description": "Second image is tagged with 'vacation_2024'"
    },
    {
      "command": "check-image-tagged 3 vacation_2024",
      "key": "tagged",
      "expected": true,
      "description": "Third image is tagged with 'vacation_2024'"
    },
    {
      "command": "check-image-rating 1 3",
      "key": "matches",
      "expected": true,
      "description": "First image rating is 3 stars"
    },
    {
      "command": "check-image-rating 2 3",
      "key": "matches",
      "expected": true,
      "description": "Second image rating is 3 stars"
    },
    {
      "command": "check-image-rating 3 3",
      "key": "matches",
      "expected": true,
      "description": "Third image rating is 3 stars"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 4,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
