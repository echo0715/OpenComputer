{
  "id": "impress_reorganize_slides",
  "app": "libreoffice_impress",
  "task": "/home/user/Documents/project_plan.pptx is open in LibreOffice Impress — a 6-slide deck with titles in order: 'Cover', 'Timeline', 'Budget', 'Team', 'Risks', 'Summary'.\n\nReorder the slides so the final order is 'Cover', 'Team', 'Timeline', 'Budget', 'Risks', 'Summary' (move 'Team' from position 4 to position 2 and shift the rest accordingly), then append a new slide at the end with:\n- Title: 'Appendix'\n- Body: 'Additional reference materials available upon request.'\n\nThe final deck must have exactly 7 slides. Save the file back to /home/user/Documents/project_plan.pptx.",
  "env": {
    "files": [
      {
        "filename": "project_plan.pptx",
        "sandbox_path": "/home/user/Documents/project_plan.pptx"
      }
    ]
  },
  "verification": [
    {
      "command": "check-slide-count 7",
      "key": "match",
      "expected": true,
      "description": "Presentation has exactly 7 slides"
    },
    {
      "command": "check-slide-title 0 \"Cover\"",
      "key": "match",
      "expected": true,
      "description": "Slide 1 title is 'Cover'"
    },
    {
      "command": "check-slide-title 1 \"Team\"",
      "key": "match",
      "expected": true,
      "description": "Slide 2 title is 'Team'"
    },
    {
      "command": "check-slide-title 2 \"Timeline\"",
      "key": "match",
      "expected": true,
      "description": "Slide 3 title is 'Timeline'"
    },
    {
      "command": "check-slide-title 3 \"Budget\"",
      "key": "match",
      "expected": true,
      "description": "Slide 4 title is 'Budget'"
    },
    {
      "command": "check-slide-title 4 \"Risks\"",
      "key": "match",
      "expected": true,
      "description": "Slide 5 title is 'Risks'"
    },
    {
      "command": "check-slide-title 5 \"Summary\"",
      "key": "match",
      "expected": true,
      "description": "Slide 6 title is 'Summary'"
    },
    {
      "command": "check-slide-title 6 \"Appendix\"",
      "key": "match",
      "expected": true,
      "description": "Slide 7 title is 'Appendix'"
    },
    {
      "command": "check-slide-contains 6 \"Additional reference materials available upon request\"",
      "key": "contains",
      "expected": true,
      "description": "Slide 7 contains the expected body text"
    },
    {
      "command": "check-file-saved",
      "key": "saved",
      "expected": true,
      "description": "File has been saved"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 4,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
