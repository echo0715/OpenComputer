{
  "id": "gimp_canvas_resize_center",
  "app": "gimp",
  "task": "Open /home/user/Documents/small_icon.png in GIMP — a 100x100 solid blue (RGB 0,0,255) image.\n\nExpand the canvas to 300x300 pixels with the original 100x100 blue square centered in the middle, and fill the new border area with solid white (RGB 255,255,255). Export the flattened result as PNG to /home/user/Documents/icon_padded.png.",
  "env": {
    "files": [
      {
        "filename": "small_icon.png",
        "sandbox_path": "/home/user/Documents/small_icon.png"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/icon_padded.png",
      "key": "exists",
      "expected": true,
      "description": "Exported padded PNG file exists"
    },
    {
      "command": "check-file-dimensions /home/user/Documents/icon_padded.png 300 300",
      "key": "match",
      "expected": true,
      "description": "Image dimensions are 300x300 pixels"
    },
    {
      "command": "check-pixel-color-file /home/user/Documents/icon_padded.png 10 10 255 255 255",
      "key": "match",
      "expected": true,
      "description": "Corner pixel is white (padded border area)"
    },
    {
      "command": "check-pixel-color-file /home/user/Documents/icon_padded.png 150 150 0 0 255",
      "key": "match",
      "expected": true,
      "description": "Center pixel is blue (original image content)"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 4,
    "estimated_difficulty": 4
  }
}
