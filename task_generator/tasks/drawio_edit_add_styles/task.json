{
  "id": "drawio_edit_add_styles",
  "app": "drawio",
  "task": "/home/user/Documents/workflow.drawio contains 3 sequentially connected shapes with white fill: 'Draft' (cell id 2), 'Review' (cell id 3), 'Published' (cell id 4).\n\nApply these changes:\n1. Set fillColor of 'Draft' to #fff2cc (yellow).\n2. Set fillColor of 'Review' to #dae8fc (blue).\n3. Set fillColor of 'Published' to #d5e8d4 (green).\n4. Add a new shape labeled 'Archived' with fillColor #f8cecc (red).\n5. Draw an arrow from 'Published' to 'Archived'.\n\nThe final diagram must have exactly 4 vertices and exactly 3 edges. Persist to /home/user/Documents/workflow.drawio.",
  "env": {
    "files": [
      {
        "filename": "workflow.drawio",
        "sandbox_path": "/home/user/Documents/workflow.drawio"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/workflow.drawio",
      "key": "exists",
      "expected": true,
      "description": "Diagram file exists at expected path"
    },
    {
      "command": "check-label-exists /home/user/Documents/workflow.drawio Draft",
      "key": "exists",
      "expected": true,
      "description": "Shape 'Draft' still exists"
    },
    {
      "command": "check-label-exists /home/user/Documents/workflow.drawio Review",
      "key": "exists",
      "expected": true,
      "description": "Shape 'Review' still exists"
    },
    {
      "command": "check-label-exists /home/user/Documents/workflow.drawio Published",
      "key": "exists",
      "expected": true,
      "description": "Shape 'Published' still exists"
    },
    {
      "command": "check-label-exists /home/user/Documents/workflow.drawio Archived",
      "key": "exists",
      "expected": true,
      "description": "New shape 'Archived' was added"
    },
    {
      "command": "check-style-property /home/user/Documents/workflow.drawio 2 fillColor \"#fff2cc\"",
      "key": "match",
      "expected": true,
      "description": "'Draft' (id 2) has yellow fill color #fff2cc"
    },
    {
      "command": "check-style-property /home/user/Documents/workflow.drawio 3 fillColor \"#dae8fc\"",
      "key": "match",
      "expected": true,
      "description": "'Review' (id 3) has blue fill color #dae8fc"
    },
    {
      "command": "check-style-property /home/user/Documents/workflow.drawio 4 fillColor \"#d5e8d4\"",
      "key": "match",
      "expected": true,
      "description": "'Published' (id 4) has green fill color #d5e8d4"
    },
    {
      "command": "check-vertex-count /home/user/Documents/workflow.drawio 4",
      "key": "match",
      "expected": true,
      "description": "Exactly 4 vertices (3 original + 1 new 'Archived')"
    },
    {
      "command": "check-edge-count /home/user/Documents/workflow.drawio 3",
      "key": "match",
      "expected": true,
      "description": "Exactly 3 edges (2 original + 1 new Published->Archived)"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 4,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
