      {"filename": "scripts/menu_controller.gd", "sandbox_path": "/home/user/godot_projects/multi_signal_game/scripts/menu_controller.gd"},
      {"filename": "icon.svg", "sandbox_path": "/home/user/godot_projects/multi_signal_game/icon.svg"}
    ]
  },
