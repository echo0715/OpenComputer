{
  "id": "audacity_gap_pitch_change",
  "app": "audacity",
  "task": "Audacity is open with /home/user/Music/source_a4.wav loaded — a 3-second 440 Hz sine tone at amplitude 0.5, mono 44.1 kHz.\n\nRaise the pitch of the entire audio by +12 semitones (one octave up, from A4 440 Hz to A5 880 Hz) while keeping the duration at 3.0 seconds, then export the result to /home/user/Music/pitched.wav as 'WAV (Microsoft) signed 16-bit PCM' at 44100 Hz mono.",
  "env": {
    "files": [
      {
        "filename": "source_a4.wav",
        "sandbox_path": "/home/user/Music/source_a4.wav"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Music/pitched.wav",
      "key": "exists",
      "expected": true,
      "description": "Pitched WAV exists"
    },
    {
      "command": "check-export-codec /home/user/Music/pitched.wav pcm_s16le",
      "key": "match",
      "expected": true,
      "description": "Codec pcm_s16le"
    },
    {
      "command": "check-export-channels /home/user/Music/pitched.wav 1",
      "key": "match",
      "expected": true,
      "description": "Mono"
    },
    {
      "command": "check-export-duration-min /home/user/Music/pitched.wav 2.8",
      "key": "match",
      "expected": true,
      "description": "Duration ~3s (pitch shift preserves duration)"
    },
    {
      "command": "export-info /home/user/Music/pitched.wav",
      "eval": "float(result['format']['duration']) <= 3.2",
      "description": "Duration <= 3.2s (not tempo-shifted)"
    },
    {
      "command": "check-export-dominant-freq /home/user/Music/pitched.wav 0.5 2.5 880 5",
      "key": "match",
      "expected": true,
      "description": "Dominant frequency raised to ~880 Hz (one octave up)"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "estimated_difficulty": 4
  }
}
