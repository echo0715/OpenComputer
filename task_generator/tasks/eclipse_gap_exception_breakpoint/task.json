{
  "id": "eclipse_gap_exception_breakpoint",
  "app": "eclipse",
  "task": "Eclipse is open with the workspace at /home/user/workspace, which contains the project 'DemoApp'.\n\nAdd a Java Exception Breakpoint for `java.lang.NullPointerException` that suspends on BOTH caught and uncaught exceptions, then export all breakpoints to /home/user/workspace/breakpoints.xml.",
  "env": {
    "files": [
      {
        "filename": "DemoApp/.project",
        "sandbox_path": "/home/user/workspace/DemoApp/.project"
      },
      {
        "filename": "DemoApp/.classpath",
        "sandbox_path": "/home/user/workspace/DemoApp/.classpath"
      },
      {
        "filename": "DemoApp/src/com/example/App.java",
        "sandbox_path": "/home/user/workspace/DemoApp/src/com/example/App.java"
      },
      {
        "filename": "DemoApp/src/com/example/Service.java",
        "sandbox_path": "/home/user/workspace/DemoApp/src/com/example/Service.java"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/workspace/breakpoints.xml",
      "key": "exists",
      "expected": true,
      "description": "Breakpoints export exists"
    },
    {
      "command": "check-exception-breakpoint /home/user/workspace java.lang.NullPointerException",
      "key": "exists",
      "expected": true,
      "description": "NPE exception breakpoint present"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "estimated_difficulty": 4
  }
}
