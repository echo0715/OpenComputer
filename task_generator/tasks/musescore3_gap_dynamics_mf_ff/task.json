{
  "id": "musescore3_gap_dynamics_mf_ff",
  "app": "musescore3",
  "task": "MuseScore 3 is open with /home/user/Documents/dynamic_arc.mscz.\n\nAdd a mezzo-forte (mf) dynamic marking at the first note of measure 1 and a fortissimo (ff) dynamic marking at the first note of measure 3. Save in place at /home/user/Documents/dynamic_arc.mscz.",
  "env": {
    "files": [
      {
        "filename": "dynamic_arc.mscz",
        "sandbox_path": "/home/user/Documents/dynamic_arc.mscz"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/dynamic_arc.mscz",
      "key": "exists",
      "expected": true,
      "description": "File saved"
    },
    {
      "command": "check-dynamic-in-measure /home/user/Documents/dynamic_arc.mscz 1 mf",
      "key": "match",
      "expected": true,
      "description": "mf dynamic at measure 1"
    },
    {
      "command": "check-dynamic-in-measure /home/user/Documents/dynamic_arc.mscz 3 ff",
      "key": "match",
      "expected": true,
      "description": "ff dynamic at measure 3"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "estimated_difficulty": 4
  }
}
