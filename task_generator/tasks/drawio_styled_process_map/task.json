{
  "id": "drawio_styled_process_map",
  "app": "drawio",
  "task": "Create a color-coded business process map in /home/user/Documents/process_map.drawio with exactly 5 shapes in a sequential flow:\n1. 'Receive Order' — fillColor #d5e8d4 (green)\n2. 'Validate Order' — fillColor #dae8fc (blue)\n3. 'Process Payment' — fillColor #dae8fc (blue)\n4. 'Ship Items' — fillColor #fff2cc (orange/yellow)\n5. 'Complete' — fillColor #d5e8d4 (green)\n\nSequential edges: Receive Order -> Validate Order -> Process Payment -> Ship Items -> Complete.\n\nFinal counts: exactly 5 vertices and exactly 4 edges. Persist to /home/user/Documents/process_map.drawio.",
  "env": {
    "files": [
      {
        "filename": "process_map.drawio",
        "sandbox_path": "/home/user/Documents/process_map.drawio"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/process_map.drawio",
      "key": "exists",
      "expected": true,
      "description": "Diagram file exists at expected path"
    },
    {
      "command": "check-label-exists /home/user/Documents/process_map.drawio \"Receive Order\"",
      "key": "exists",
      "expected": true,
      "description": "Shape 'Receive Order' exists"
    },
    {
      "command": "check-label-exists /home/user/Documents/process_map.drawio \"Validate Order\"",
      "key": "exists",
      "expected": true,
      "description": "Shape 'Validate Order' exists"
    },
    {
      "command": "check-label-exists /home/user/Documents/process_map.drawio \"Process Payment\"",
      "key": "exists",
      "expected": true,
      "description": "Shape 'Process Payment' exists"
    },
    {
      "command": "check-label-exists /home/user/Documents/process_map.drawio \"Ship Items\"",
      "key": "exists",
      "expected": true,
      "description": "Shape 'Ship Items' exists"
    },
    {
      "command": "check-label-exists /home/user/Documents/process_map.drawio Complete",
      "key": "exists",
      "expected": true,
      "description": "Shape 'Complete' exists"
    },
    {
      "command": "check-vertex-count /home/user/Documents/process_map.drawio 5",
      "key": "match",
      "expected": true,
      "description": "Exactly 5 vertex shapes"
    },
    {
      "command": "check-edge-count /home/user/Documents/process_map.drawio 4",
      "key": "match",
      "expected": true,
      "description": "Exactly 4 edges connecting shapes sequentially"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
