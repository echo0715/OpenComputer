{
  "id": "audacity_export_mp3_stereo",
  "app": "audacity",
  "task": "Audacity is open with /home/user/Music/source.wav already loaded (a 3-second stereo 44.1 kHz WAV file).\n\nExport this audio as an MP3 file to /home/user/Music/song.mp3 using the default 'Standard, 170-210 kbps' bit-rate preset.",
  "env": {
    "files": [
      {
        "filename": "source.wav",
        "sandbox_path": "/home/user/Music/source.wav"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Music/song.mp3",
      "key": "exists",
      "expected": true,
      "description": "Exported MP3 exists"
    },
    {
      "command": "check-export-codec /home/user/Music/song.mp3 mp3",
      "key": "match",
      "expected": true,
      "description": "Codec is mp3"
    },
    {
      "command": "check-export-channels /home/user/Music/song.mp3 2",
      "key": "match",
      "expected": true,
      "description": "MP3 has 2 channels (stereo)"
    },
    {
      "command": "check-export-duration-min /home/user/Music/song.mp3 2.5",
      "key": "match",
      "expected": true,
      "description": "MP3 duration is at least 2.5 seconds"
    }
  ],
  "metadata": {
    "complexity": 3,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 3
  }
}
