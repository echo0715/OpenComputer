{
  "id": "vlc_set_volume_75",
  "app": "vlc",
  "task": "VLC is already running. Open /home/user/Videos/sample.mp4, begin playback, and set VLC's audio volume to exactly 75% (reduced from VLC's default of 100%). Leave sample.mp4 playing at 75% volume; do not mute, pause, or close VLC.",
  "env": {
    "files": [
      {
        "filename": "sample.mp4",
        "sandbox_path": "/home/user/Videos/sample.mp4"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Videos/sample.mp4",
      "key": "exists",
      "expected": true,
      "description": "Source sample.mp4 exists"
    },
    {
      "command": "check-media-loaded sample.mp4",
      "key": "loaded",
      "expected": true,
      "description": "sample.mp4 is loaded in VLC"
    },
    {
      "command": "check-playing",
      "key": "playing",
      "expected": true,
      "description": "VLC is currently playing"
    },
    {
      "command": "check-volume 75",
      "key": "match",
      "expected": true,
      "description": "Volume is at 75%"
    }
  ],
  "metadata": {
    "complexity": 3,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 3
  }
}
