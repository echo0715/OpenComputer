{
  "id": "vscode_full_workspace_config",
  "app": "vscode",
  "task": "Create a project workspace at `/home/user/projects/flask-api` with the following files:\n\n- `app.py`:\n  ```python\n  from flask import Flask, jsonify\n  app = Flask(__name__)\n\n  @app.route('/health')\n  def health():\n      return jsonify(status='ok')\n\n  if __name__ == '__main__':\n      app.run(debug=True)\n  ```\n- `.vscode/settings.json` — `python.defaultInterpreterPath: /usr/bin/python3`, `editor.formatOnSave: true`.\n- `.vscode/launch.json` — a configuration named `Flask App`, type `debugpy`, request `launch`, running `app.py`.\n- `.vscode/tasks.json` — two shell tasks:\n  - `Run Server` — runs `python3 app.py`\n  - `Run Tests` — runs `python3 -m pytest`\n- `.vscode/extensions.json` — recommends `ms-python.python`.",
  "env": {
    "files": []
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/projects/flask-api/app.py",
      "key": "exists",
      "expected": true,
      "description": "app.py exists"
    },
    {
      "command": "check-file-contains /home/user/projects/flask-api/app.py Flask",
      "key": "contains",
      "expected": true,
      "description": "app.py contains Flask"
