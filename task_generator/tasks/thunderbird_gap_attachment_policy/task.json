{
  "id": "thunderbird_gap_attachment_policy",
  "app": "thunderbird",
  "task": "Harden Thunderbird's attachment handling so that:\n- The directory `/home/user/Documents/Attachments` exists on disk.\n- `browser.download.dir` = `/home/user/Documents/Attachments` (default attachment save directory).\n- `mail.inline_attachments` = `false` (inline display of attached images disabled).\n- `mail.compose.big_attachments.threshold_kb` = `5120` (big-attachment warning threshold = 5120 KB).\n- `mail.compose.big_attachments.notify` = `true` (big-attachment warning enabled).",
  "env": {
    "files": [
      {
        "filename": "thunderbird-profile.tar.gz",
        "sandbox_path": "/tmp/thunderbird-profile.tar.gz"
      }
    ]
  },
  "verification": [
    {
      "command": "check-directory-exists /home/user/Documents/Attachments",
      "key": "exists",
      "expected": true,
      "description": "Attachments directory exists"
    },
    {
      "command": "check-pref-value browser.download.dir /home/user/Documents/Attachments",
      "key": "match",
      "expected": true,
      "description": "Default download dir is set"
    },
    {
      "command": "check-pref-value mail.inline_attachments false",
      "key": "match",
      "expected": true,
      "description": "Inline attachments disabled"
    },
    {
      "command": "check-pref-value mail.compose.big_attachments.threshold_kb 5120",
      "key": "match",
      "expected": true,
      "description": "Big-attachment threshold is 5120 KB"
    },
    {
      "command": "check-pref-value mail.compose.big_attachments.notify true",
      "key": "match",
      "expected": true,
      "description": "Big-attachment warning enabled"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 4,
    "estimated_difficulty": 4
  }
}
