{
  "id": "kdenlive_effect_and_render",
  "app": "kdenlive",
  "task": "Kdenlive is already open with the project file at /home/user/Documents/render_project.kdenlive (1920x1080, 30fps).\n\nImport /home/user/Videos/demo.mp4 onto a video track in the timeline, apply the Cartoon effect (`frei0r.cartoon`) to that timeline clip, and save the project so the changes are persisted to /home/user/Documents/render_project.kdenlive. Then render the project to /home/user/Documents/output.mp4 using the MP4 / H.264 preset; the output file must exist and be a valid media file. The project must remain at 1920x1080, 30fps.",
  "env": {
    "files": [
      {
        "filename": "render_project.kdenlive",
        "sandbox_path": "/home/user/Documents/render_project.kdenlive"
      },
      {
        "filename": "demo.mp4",
        "sandbox_path": "/home/user/Videos/demo.mp4"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/render_project.kdenlive",
      "key": "exists",
      "expected": true,
      "description": "Project file exists at /home/user/Documents/render_project.kdenlive"
    },
    {
      "command": "check-resolution /home/user/Documents/render_project.kdenlive 1920 1080",
      "key": "match",
      "expected": true,
      "description": "Project resolution is 1920x1080"
    },
    {
      "command": "check-fps /home/user/Documents/render_project.kdenlive 30",
      "key": "match",
      "expected": true,
      "description": "Project frame rate is 30 fps"
    },
    {
      "command": "check-clip-exists /home/user/Documents/render_project.kdenlive demo.mp4",
      "key": "exists",
      "expected": true,
      "description": "Clip demo.mp4 is in the project"
    },
    {
      "command": "check-effect-exists /home/user/Documents/render_project.kdenlive frei0r.cartoon",
      "key": "exists",
      "expected": true,
      "description": "Cartoon effect (frei0r.cartoon) is applied in the project"
    },
    {
      "command": "check-file-exists /home/user/Documents/output.mp4",
      "key": "exists",
      "expected": true,
      "description": "Rendered output file exists at /home/user/Documents/output.mp4"
    },
    {
      "command": "check-render-output /home/user/Documents/output.mp4",
      "key": "exists",
      "expected": true,
      "description": "Rendered output is a valid media file"
    }
  ],
  "metadata": {
    "complexity": 5,
    "data_generatability": 4,
    "verification_determinism": 5,
    "estimated_difficulty": 5
  }
}
