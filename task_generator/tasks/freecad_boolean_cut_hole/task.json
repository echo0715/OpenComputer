{
  "id": "freecad_boolean_cut_hole",
  "app": "freecad",
  "task": "FreeCAD is open with /home/user/Documents/bolted.FCStd, which contains a Part::Box named 'Box' and a Part::Cylinder named 'Cylinder' already positioned so the cylinder passes through the box.\n\nPerform a boolean Cut with 'Box' as the base and 'Cylinder' as the tool, producing a new Part::Cut object named 'Cut'. Save the file.",
  "env": {
    "files": [
      {
        "filename": "bolted.FCStd",
        "sandbox_path": "/home/user/Documents/bolted.FCStd"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/bolted.FCStd",
      "key": "exists",
      "expected": true,
      "description": "File exists"
    },
    {
      "command": "check-object-exists /home/user/Documents/bolted.FCStd Cut",
      "key": "exists",
      "expected": true,
      "description": "Cut object exists"
    },
    {
      "command": "check-object-type /home/user/Documents/bolted.FCStd Cut Part::Cut",
      "key": "match",
      "expected": true,
      "description": "Cut object is of type Part::Cut"
    },
    {
      "command": "check-object-type-count /home/user/Documents/bolted.FCStd Part::Cut 1",
      "key": "match",
      "expected": true,
      "description": "Exactly one Part::Cut object"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
