{
  "id": "freecad_gap_path_cam_job",
  "app": "freecad",
  "task": "FreeCAD is open with /home/user/Documents/path_start.FCStd, which contains a Part::Box named 'Stock' (80 x 60 x 10 mm).\n\nCreate a Path (CAM) Job named exactly 'CNCJob' that references 'Stock' as the model. The Job must contain exactly one Tool Controller named exactly 'TC_EndMill6' using a 6 mm diameter end mill, and one Profile operation named exactly 'ProfileOp' that contours the outer boundary of Stock. Save the file.",
  "env": {
    "files": [
      {
        "filename": "path_start.FCStd",
        "sandbox_path": "/home/user/Documents/path_start.FCStd"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/path_start.FCStd",
      "key": "exists",
      "expected": true,
      "description": "File exists"
    },
    {
      "command": "check-object-exists /home/user/Documents/path_start.FCStd Stock",
      "key": "exists",
      "expected": true,
      "description": "Stock preserved"
    },
    {
      "command": "check-object-exists /home/user/Documents/path_start.FCStd CNCJob",
      "key": "exists",
      "expected": true,
      "description": "CNCJob exists"
    },
    {
      "command": "check-object-type /home/user/Documents/path_start.FCStd CNCJob Path::FeatureCompoundPython",
      "key": "match",
      "expected": true,
      "description": "CNCJob is a Path Job (Path::FeatureCompoundPython)"
    },
    {
      "command": "check-object-exists /home/user/Documents/path_start.FCStd TC_EndMill6",
      "key": "exists",
      "expected": true,
      "description": "TC_EndMill6 tool controller exists"
    },
    {
      "command": "check-object-exists /home/user/Documents/path_start.FCStd ProfileOp",
      "key": "exists",
      "expected": true,
      "description": "ProfileOp operation exists"
    }
  ],
  "metadata": {
    "complexity": 5,
    "data_generatability": 4,
    "estimated_difficulty": 5
  }
}
