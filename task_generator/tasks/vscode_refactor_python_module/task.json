{
  "id": "vscode_refactor_python_module",
  "app": "vscode",
  "task": "`/home/user/Documents/calculator.py` is a simple calculator module with three bugs. Fix the file (overwriting the same path) so that:\n\n1. The misspelled function `substract` is renamed to `subtract`; its body should continue to compute `a - b`.\n2. The `multiply` function returns `a * b` (currently returns `a + b`).\n3. The `divide` function ends with `return result` (or equivalent) so it returns the quotient `a / b`.\n4. Each of the four functions (`add`, `subtract`, `multiply`, `divide`) has a one-line triple-quoted docstring immediately after its signature. The docstrings must contain these words respectively: `add` → `sum`, `subtract` → `difference`, `multiply` → `product`, `divide` → `quotient`.",
  "env": {
    "files": [
      {
        "filename": "calculator.py",
        "sandbox_path": "/home/user/Documents/calculator.py"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/calculator.py",
      "key": "exists",
      "expected": true,
      "description": "calculator.py still exists after edits"
    },
    {
      "command": "check-file-contains /home/user/Documents/calculator.py def subtract",
      "key": "contains",
      "expected": true,
      "description": "subtract function is correctly named"
    },
    {
      "command": "check-file-contains /home/user/Documents/calculator.py a * b",
      "key": "contains",
      "expected": true,
      "description": "multiply uses a * b"
    },
    {
      "command": "check-file-contains /home/user/Documents/calculator.py return result",
      "key": "contains",
      "expected": true,
      "description": "divide returns the result"
    },
    {
      "command": "check-file-contains /home/user/Documents/calculator.py sum",
      "key": "contains",
      "expected": true,
      "description": "add docstring mentions sum"
    },
    {
      "command": "check-file-contains /home/user/Documents/calculator.py difference",
      "key": "contains",
      "expected": true,
      "description": "subtract docstring mentions difference"
    },
    {
      "command": "check-file-contains /home/user/Documents/calculator.py product",
      "key": "contains",
      "expected": true,
      "description": "multiply docstring mentions product"
    },
    {
      "command": "check-file-contains /home/user/Documents/calculator.py quotient",
      "key": "contains",
      "expected": true,
      "description": "divide docstring mentions quotient"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
