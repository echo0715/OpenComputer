{
  "id": "calc_inventory_reorder_flags",
  "app": "libreoffice_calc",
  "task": "Open /home/user/Documents/stock.xlsx in LibreOffice Calc. The 'Stock' sheet has columns SKU (A), Item (B), On Hand (C), Daily Usage (D), Reorder Point (E), Max Stock (F) for 15 items in rows 2-16.\n\nExtend 'Stock':\n- Bold headers: G1='Days of Supply', H1='Status', I1='Reorder Qty'.\n- G2:G16 = `=C2/D2` filled down.\n- H2:H16 = `=IF(C2<E2/2,\"Critical\",IF(C2<E2,\"Low\",\"OK\"))` filled down.\n- I2:I16 = `=IF(OR(H2=\"Critical\",H2=\"Low\"),F2-C2,0)` filled down.\n\nAdd a new sheet 'StatusSummary' with:\n- Bold headers: A1='Status', B1='Count'.\n- A2='Critical', A3='Low', A4='OK'.\n- B2 = `=COUNTIF(Stock.H2:H16,A2)`, B3 = `=COUNTIF(Stock.H2:H16,A3)`, B4 = `=COUNTIF(Stock.H2:H16,A4)`.\n\nSave the file.",
  "env": {
    "files": [
      {
        "filename": "stock.xlsx",
        "sandbox_path": "/home/user/Documents/stock.xlsx"
      }
    ]
  },
  "verification": [
    {
      "command": "check-cell-value G1 \"Days of Supply\" Stock",
      "key": "match",
      "expected": true,
      "description": "G1 = Days of Supply"
    },
    {
      "command": "check-cell-value H1 Status Stock",
      "key": "match",
      "expected": true,
      "description": "H1 = Status"
    },
    {
      "command": "check-cell-value I1 \"Reorder Qty\" Stock",
      "key": "match",
      "expected": true,
      "description": "I1 = Reorder Qty"
    },
    {
      "command": "check-cell-formatted G1 true Stock",
      "key": "match",
      "expected": true,
      "description": "G1 bold"
    },
    {
      "command": "check-cell-value G2 6 Stock",
      "key": "match",
      "expected": true,
      "description": "G2 Bolts days = 6"
    },
    {
      "command": "check-cell-value G3 2.5 Stock",
      "key": "match",
      "expected": true,
      "description": "G3 Nuts days = 2.5"
    },
    {
      "command": "check-cell-value H2 Low Stock",
      "key": "match",
      "expected": true,
      "description": "H2 Bolts = Low"
    },
    {
      "command": "check-cell-value H3 Critical Stock",
      "key": "match",
      "expected": true,
      "description": "H3 Nuts = Critical"
    },
    {
      "command": "check-cell-value H4 OK Stock",
      "key": "match",
      "expected": true,
      "description": "H4 Washers = OK"
    },
    {
      "command": "check-cell-value H5 Critical Stock",
      "key": "match",
      "expected": true,
      "description": "H5 Screws = Critical"
    },
    {
      "command": "check-cell-value H13 Critical Stock",
      "key": "match",
      "expected": true,
      "description": "H13 Springs = Critical"
    },
    {
      "command": "check-cell-value H16 Critical Stock",
      "key": "match",
      "expected": true,
      "description": "H16 Valves = Critical"
    },
    {
      "command": "check-cell-value I2 170 Stock",
      "key": "match",
      "expected": true,
      "description": "I2 Bolts reorder = 170"
    },
    {
      "command": "check-cell-value I4 0 Stock",
      "key": "match",
      "expected": true,
      "description": "I4 Washers reorder = 0 (OK)"
    },
    {
      "command": "check-cell-value I5 145 Stock",
      "key": "match",
      "expected": true,
      "description": "I5 Screws reorder = 145"
    },
    {
      "command": "cell-value H2 Stock",
      "eval": "result.get('formula') is not None and result.get('formula','').upper().count('IF') >= 2",
      "description": "H2 is nested IF"
    },
    {
      "command": "check-sheet-exists StatusSummary",
      "key": "exists",
      "expected": true,
      "description": "StatusSummary sheet exists"
    },
    {
      "command": "check-cell-value A1 Status StatusSummary",
      "key": "match",
      "expected": true,
      "description": "StatusSummary A1 = Status"
    },
    {
      "command": "check-cell-value B1 Count StatusSummary",
      "key": "match",
      "expected": true,
      "description": "StatusSummary B1 = Count"
    },
    {
      "command": "check-cell-formatted A1 true StatusSummary",
      "key": "match",
      "expected": true,
      "description": "StatusSummary A1 bold"
    },
    {
      "command": "check-cell-value A2 Critical StatusSummary",
      "key": "match",
      "expected": true,
      "description": "StatusSummary A2 = Critical"
    },
    {
      "command": "check-cell-value B2 6 StatusSummary",
      "key": "match",
      "expected": true,
      "description": "StatusSummary B2 (Critical count) = 6"
    },
    {
      "command": "check-cell-value B3 4 StatusSummary",
      "key": "match",
      "expected": true,
      "description": "StatusSummary B3 (Low count) = 4"
    },
    {
      "command": "check-cell-value B4 5 StatusSummary",
      "key": "match",
      "expected": true,
      "description": "StatusSummary B4 (OK count) = 5"
    },
    {
      "command": "cell-value B2 StatusSummary",
      "eval": "result.get('formula') is not None and 'COUNTIF' in result.get('formula','').upper()",
      "description": "StatusSummary B2 uses COUNTIF"
    },
    {
      "command": "check-file-saved",
      "key": "saved",
      "expected": true,
      "description": "File has been saved"
    }
  ],
  "metadata": {
    "complexity": 5,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 5
  }
}
