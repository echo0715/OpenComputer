{
  "id": "draw_state_machine_traffic",
  "app": "libreoffice_draw",
  "task": "/home/user/Documents/state_seed.odg is open in LibreOffice Draw — page 1 already contains a single ellipse labeled 'Red'.\n\nBuild a traffic-light state machine on page 1, preserving the 'Red' ellipse:\n- Three additional ellipses labelled exactly 'Green', 'Yellow', 'Flashing Red'.\n- One rectangle labelled exactly 'Fault Mode'.\n- Connectors representing transitions: 'Red' → 'Green'; 'Green' → 'Yellow'; 'Yellow' → 'Red'; 'Red' → 'Flashing Red'; 'Flashing Red' → 'Fault Mode'.\n\nPage 1 must end up with at least 5 shapes (4 ellipses + Fault Mode rectangle).\n\nAdd a new page 2 containing two rectangles labelled exactly 'Transition Legend' and 'Authored by Ops Team'. The document must end up with exactly 2 pages. Save the file in-place to /home/user/Documents/state_seed.odg.",
  "env": {
    "files": [
      {
        "filename": "state_seed.odg",
        "sandbox_path": "/home/user/Documents/state_seed.odg"
      }
    ]
  },
  "verification": [
    {
      "command": "check-page-count 2",
      "key": "match",
      "expected": true,
      "description": "Document has exactly 2 pages"
    },
    {
      "command": "check-page-contains 0 Red",
      "key": "contains",
      "expected": true,
      "description": "Page 1 still contains 'Red'"
    },
    {
      "command": "check-page-contains 0 Green",
      "key": "contains",
      "expected": true,
      "description": "Page 1 contains 'Green'"
    },
    {
      "command": "check-page-contains 0 Yellow",
      "key": "contains",
      "expected": true,
      "description": "Page 1 contains 'Yellow'"
    },
    {
      "command": "check-page-contains 0 \"Flashing Red\"",
      "key": "contains",
      "expected": true,
      "description": "Page 1 contains 'Flashing Red'"
    },
    {
      "command": "check-page-contains 0 \"Fault Mode\"",
      "key": "contains",
      "expected": true,
      "description": "Page 1 contains 'Fault Mode'"
    },
    {
      "command": "check-shape-exists 0 EllipseShape",
      "key": "exists",
      "expected": true,
      "description": "Page 1 has ellipse shapes"
    },
    {
      "command": "check-shape-exists 0 RectangleShape",
      "key": "exists",
      "expected": true,
      "description": "Page 1 has rectangle shapes"
    },
    {
      "command": "pages",
      "eval": "result['pages'][0]['shape_count'] >= 5",
      "description": "Page 1 has at least 5 shapes (4 ellipses + Fault Mode rectangle)"
    },
    {
      "command": "check-page-contains 1 \"Transition Legend\"",
      "key": "contains",
      "expected": true,
      "description": "Page 2 contains 'Transition Legend'"
    },
    {
      "command": "check-page-contains 1 \"Authored by Ops Team\"",
      "key": "contains",
      "expected": true,
      "description": "Page 2 contains 'Authored by Ops Team'"
    },
    {
      "command": "check-file-saved",
      "key": "saved",
      "expected": true,
      "description": "File has been saved"
    }
  ],
  "metadata": {
    "complexity": 5,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 5
  }
}
