    {
      "command": "check-file-contains /home/user/projects/docker-app/docker-compose.yml postgres",
      "key": "contains",
      "expected": true,
      "description": "docker-compose uses postgres image"
    },
    {
      "command": "check-file-exists /home/user/projects/docker-app/requirements.txt",
      "key": "exists",
      "expected": true,
      "description": "requirements.txt exists"
