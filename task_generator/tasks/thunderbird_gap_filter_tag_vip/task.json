{
  "id": "thunderbird_gap_filter_tag_vip",
  "app": "thunderbird",
  "task": "Create an enabled Thunderbird message filter on the Local Folders account named exactly `VIP Senders` with these properties:\n- Triggers only when getting new mail (not when run manually).\n- Three conditions combined with OR: From contains `@acme-corp.com`, From contains `@globalventures.io`, From contains `@partner-bank.net`.\n- One action: tag matching messages with the built-in `Important` label (tag key `$label1`).",
  "env": {
    "files": [
      {
        "filename": "thunderbird-profile.tar.gz",
        "sandbox_path": "/tmp/thunderbird-profile.tar.gz"
      }
    ]
  },
  "verification": [
    {
      "command": "check-filter-exists 'VIP Senders'",
      "key": "found",
      "expected": true,
      "description": "Filter 'VIP Senders' exists"
    },
    {
      "command": "check-filter-action 'VIP Senders' AddTag '$label1'",
      "key": "match",
      "expected": true,
      "description": "Filter action tags with $label1 (Important)"
    },
    {
      "command": "check-filter-condition 'VIP Senders' acme-corp.com",
      "key": "match",
      "expected": true,
      "description": "Condition includes acme-corp.com"
    },
    {
      "command": "check-filter-condition 'VIP Senders' globalventures.io",
      "key": "match",
      "expected": true,
      "description": "Condition includes globalventures.io"
    },
    {
      "command": "check-filter-condition 'VIP Senders' partner-bank.net",
      "key": "match",
      "expected": true,
      "description": "Condition includes partner-bank.net"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 4,
    "estimated_difficulty": 4
  }
}
