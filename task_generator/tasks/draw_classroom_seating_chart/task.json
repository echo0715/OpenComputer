{
  "id": "draw_classroom_seating_chart",
  "app": "libreoffice_draw",
  "task": "Create a new one-page LibreOffice Draw drawing representing a classroom seating chart, and save it to /home/user/Documents/seating_chart.odg.\n\nThe page must contain:\n- A 'Teacher Desk' rectangle near the top.\n- 20 student-desk rectangles labelled exactly 'S01', 'S02', 'S03', ..., 'S20' (one label per rectangle), arranged as a 5×4 grid.\n- Two shapes/labels with the exact strings 'Window Side' and 'Door Side' anchoring the layout.\n- Two accommodation marker shapes labelled exactly 'Wheelchair Access' and 'Hearing Loop'.\n\nAlso add a custom layer named exactly 'Accessibility'. Page 1 must end up with at least 25 shapes total.",
  "env": {
    "files": []
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/seating_chart.odg",
      "key": "exists",
      "expected": true,
      "description": "Output ODG file exists"
    },
    {
      "command": "check-page-count 1",
      "key": "match",
      "expected": true,
      "description": "Document has exactly 1 page"
    },
    {
      "command": "check-layer-exists Accessibility",
      "key": "exists",
      "expected": true,
      "description": "Layer 'Accessibility' exists"
    },
    {
      "command": "check-page-contains 0 \"Teacher Desk\"",
      "key": "contains",
      "expected": true,
      "description": "Page 1 contains Teacher Desk"
    },
    {
      "command": "check-page-contains 0 \"Window Side\"",
      "key": "contains",
      "expected": true,
      "description": "Page 1 Window Side"
    },
    {
      "command": "check-page-contains 0 \"Door Side\"",
      "key": "contains",
      "expected": true,
      "description": "Page 1 Door Side"
    },
    {
