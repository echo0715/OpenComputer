{
  "id": "vlc_gap_video_adjust_brightness",
  "app": "vlc",
  "task": "Enable the 'Image adjust' video filter in VLC (video-filter chain must include 'adjust') and set brightness to 1.2 and contrast to 1.1 in preferences. Save preferences so they persist in ~/.config/vlc/vlcrc, then play /home/user/Videos/sample.mp4.",
  "env": {
    "files": [
      {"filename": "sample.mp4", "sandbox_path": "/home/user/Videos/sample.mp4"}
    ]
  },
  "verification": [
    {"command": "check-file-exists /home/user/Videos/sample.mp4", "key": "exists", "expected": true, "description": "sample.mp4 is present"},
    {"command": "config video-filter", "eval": "'adjust' in (result.get('value') or '')", "description": "video-filter chain contains adjust"},
    {"command": "check-config brightness 1.2", "key": "match", "expected": true, "description": "Brightness = 1.2"},
    {"command": "check-config contrast 1.1", "key": "match", "expected": true, "description": "Contrast = 1.1"},
    {"command": "check-media-loaded sample.mp4", "key": "loaded", "expected": true, "description": "sample.mp4 is playing"}
  ],
  "metadata": {"complexity": 4, "data_generatability": 5, "estimated_difficulty": 4}
}
