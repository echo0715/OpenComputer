{
  "id": "blender_scene_setup_objects",
  "app": "blender",
  "task": "In the Blender file open at /home/user/Documents/city_scene.blend, delete the default Cube and add three mesh objects: a UV Sphere named 'Planet', a Cube named 'Building', and a Cylinder named 'Tower'.\n\nCreate a collection named 'CityScene' containing all three objects. Set the render engine to Cycles, the render resolution to 1920x1080, and save the file.",
  "env": {
    "files": [
      {
        "filename": "city_scene.blend",
        "sandbox_path": "/home/user/Documents/city_scene.blend"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/city_scene.blend",
      "key": "exists",
      "expected": true,
      "description": "Blend file saved at expected path"
    },
    {
      "command": "check-object-exists /home/user/Documents/city_scene.blend Planet",
      "key": "exists",
      "expected": true,
      "description": "Object 'Planet' exists"
    },
    {
      "command": "check-object-type /home/user/Documents/city_scene.blend Planet MESH",
      "key": "match",
      "expected": true,
      "description": "Planet is a MESH object"
    },
    {
      "command": "check-object-exists /home/user/Documents/city_scene.blend Building",
      "key": "exists",
      "expected": true,
      "description": "Object 'Building' exists"
    },
    {
      "command": "check-object-type /home/user/Documents/city_scene.blend Building MESH",
      "key": "match",
      "expected": true,
      "description": "Building is a MESH object"
    },
    {
      "command": "check-object-exists /home/user/Documents/city_scene.blend Tower",
      "key": "exists",
      "expected": true,
      "description": "Object 'Tower' exists"
    },
    {
      "command": "check-object-type /home/user/Documents/city_scene.blend Tower MESH",
      "key": "match",
      "expected": true,
      "description": "Tower is a MESH object"
    },
    {
      "command": "check-collection-exists /home/user/Documents/city_scene.blend CityScene",
      "key": "exists",
      "expected": true,
      "description": "Collection 'CityScene' exists"
    },
    {
      "command": "check-render-engine /home/user/Documents/city_scene.blend CYCLES",
      "key": "match",
      "expected": true,
      "description": "Render engine set to CYCLES"
    },
    {
      "command": "check-resolution /home/user/Documents/city_scene.blend 1920 1080",
      "key": "match",
      "expected": true,
      "description": "Render resolution is 1920x1080"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
