{
  "id": "gedit_create_html_page",
  "app": "gedit",
  "task": "Create an HTML5 document at /home/user/Documents/index.html with a complete structure:\n\n- Line 1: `<!DOCTYPE html>`\n- An `<html>` opening tag and a closing `</html>` tag\n- A `<head>` section containing `<title>My Portfolio</title>`\n- A `<body>` section containing:\n  - An `<h1>` heading with the exact text: `Welcome to My Portfolio`\n  - A `<p>` paragraph with the exact text: `This is a sample portfolio page.`\n  - A `<ul>` list with exactly 3 `<li>` items: `Project Alpha`, `Project Beta`, `Project Gamma`\n\nThe file must have at least 14 lines.",
  "env": {
    "files": []
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/index.html",
      "key": "exists",
      "expected": true,
      "description": "index.html file was created"
    },
    {
      "command": "check-file-contains /home/user/Documents/index.html \"<!DOCTYPE html>\"",
      "key": "contains",
      "expected": true,
      "description": "File contains DOCTYPE declaration"
    },
    {
      "command": "check-file-contains /home/user/Documents/index.html \"<title>My Portfolio</title>\"",
      "key": "contains",
      "expected": true,
      "description": "File contains correct title tag"
    },
    {
      "command": "check-file-contains /home/user/Documents/index.html \"Welcome to My Portfolio\"",
      "key": "contains",
      "expected": true,
      "description": "File contains h1 heading text"
    },
    {
      "command": "check-file-contains /home/user/Documents/index.html \"This is a sample portfolio page.\"",
      "key": "contains",
      "expected": true,
      "description": "File contains paragraph text"
    },
    {
      "command": "check-file-contains /home/user/Documents/index.html \"Project Alpha\"",
      "key": "contains",
      "expected": true,
      "description": "File contains first list item"
    },
    {
      "command": "check-file-contains /home/user/Documents/index.html \"Project Beta\"",
      "key": "contains",
      "expected": true,
      "description": "File contains second list item"
    },
    {
      "command": "check-file-contains /home/user/Documents/index.html \"Project Gamma\"",
      "key": "contains",
      "expected": true,
      "description": "File contains third list item"
    },
    {
      "command": "file-line-count /home/user/Documents/index.html",
      "eval": "result.get('line_count', 0) >= 14",
      "description": "File has at least 14 lines"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
