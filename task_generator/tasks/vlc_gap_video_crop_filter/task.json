{
  "id": "vlc_gap_video_crop_filter",
  "app": "vlc",
  "task": "Configure VLC to crop 50 pixels from the top and 50 pixels from the bottom of video output (croptop = 50, cropbottom = 50 in preferences). Save preferences so they persist in ~/.config/vlc/vlcrc, then play /home/user/Videos/sample.mp4.",
  "env": {
    "files": [
      {"filename": "sample.mp4", "sandbox_path": "/home/user/Videos/sample.mp4"}
    ]
  },
  "verification": [
    {"command": "check-file-exists /home/user/Videos/sample.mp4", "key": "exists", "expected": true, "description": "sample.mp4 is present"},
    {"command": "check-config croptop 50", "key": "match", "expected": true, "description": "Crop top = 50"},
    {"command": "check-config cropbottom 50", "key": "match", "expected": true, "description": "Crop bottom = 50"},
    {"command": "check-media-loaded sample.mp4", "key": "loaded", "expected": true, "description": "sample.mp4 is playing"}
  ],
  "metadata": {"complexity": 4, "data_generatability": 5, "estimated_difficulty": 4}
}
