{
  "id": "obs_delete_unused_scenes",
  "app": "obs",
  "task": "OBS Studio is open with a scene collection that already contains 6 scenes — 'Intro', 'Main', 'BRB', 'Outro', 'Debug', 'Archive' — each holding a single placeholder source.\n\nPrune the collection so that exactly 2 scenes remain: 'Main' and 'Outro'. Delete 'Intro', 'BRB', 'Debug', and 'Archive'. Do NOT rename, add, or create any scene, and do NOT modify the contents of 'Main' or 'Outro'. Persist the changes to the scene collection JSON.",
  "env": {
    "files": [
      {
        "filename": "scene_collection.json",
        "sandbox_path": "/home/user/.config/obs-studio/basic/scenes/Untitled.json"
      }
    ]
  },
  "verification": [
    {
      "command": "check-scene-exists Main",
      "key": "exists",
      "expected": true,
      "description": "Scene 'Main' kept"
    },
    {
      "command": "check-scene-exists Outro",
      "key": "exists",
      "expected": true,
      "description": "Scene 'Outro' kept"
    },
    {
      "command": "check-scene-exists Intro",
      "key": "exists",
      "expected": false,
      "description": "Scene 'Intro' deleted"
    },
    {
      "command": "check-scene-exists BRB",
      "key": "exists",
      "expected": false,
      "description": "Scene 'BRB' deleted"
    },
    {
      "command": "check-scene-exists Debug",
      "key": "exists",
      "expected": false,
      "description": "Scene 'Debug' deleted"
    },
    {
      "command": "check-scene-exists Archive",
      "key": "exists",
      "expected": false,
      "description": "Scene 'Archive' deleted"
    },
    {
      "command": "check-scene-count 2",
      "key": "match",
      "expected": true,
      "description": "Exactly 2 scenes in collection"
    },
    {
      "command": "check-source-in-scene 'Main Cam' Main",
      "key": "exists",
      "expected": true,
      "description": "'Main Cam' still in 'Main'"
    },
    {
      "command": "check-source-in-scene 'Outro Roll' Outro",
      "key": "exists",
      "expected": true,
      "description": "'Outro Roll' still in 'Outro'"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
