{
  "id": "writer_edit_existing_table_data",
  "app": "libreoffice_writer",
  "task": "The file /home/user/Documents/sales_report.odt is open in LibreOffice Writer. The document has 'Monthly Sales Report' as a Heading 1 and contains a table named 'Table1' (5 rows × 4 columns) of sales data with some incorrect values.\n\nApply the following corrections in Table1, then save the file:\n- (row 1, col 2): '150' → '175' (Units Sold for North)\n- (row 2, col 2): '200' → '210' (Units Sold for South)\n- (row 3, col 3): '$45,000' → '$52,000' (Revenue for East)\n- (row 4, col 3): '$38,000' → '$41,500' (Revenue for West)\n\nAlso replace every occurrence of 'Q3 2025' with 'Q4 2025' in the document text (2 occurrences) and add a page footer containing the text 'Revised March 2026'. The header row of Table1 (e.g., 'Region' at (0,0)) must remain unchanged.",
  "env": {
    "files": [
      {
        "filename": "sales_report.odt",
        "sandbox_path": "/home/user/Documents/sales_report.odt"
      }
    ]
  },
  "verification": [
    {
      "command": "check-table-cell Table1 1 2 175",
      "key": "match",
      "expected": true,
      "description": "Table1 (1,2) is '175'"
    },
    {
      "command": "check-table-cell Table1 2 2 210",
      "key": "match",
      "expected": true,
      "description": "Table1 (2,2) is '210'"
    },
    {
      "command": "check-table-cell Table1 3 3 \"$52,000\"",
      "key": "match",
      "expected": true,
      "description": "Table1 (3,3) is '$52,000'"
    },
    {
      "command": "check-table-cell Table1 4 3 \"$41,500\"",
      "key": "match",
      "expected": true,
      "description": "Table1 (4,3) is '$41,500'"
    },
    {
      "command": "check-table-cell Table1 0 0 Region",
      "key": "match",
      "expected": true,
      "description": "Table1 header (0,0) still 'Region' (unchanged)"
    },
    {
      "command": "search \"Q3 2025\"",
      "eval": "result.get('count', 1) == 0",
      "description": "No occurrences of 'Q3 2025' remain"
    },
    {
      "command": "search \"Q4 2025\"",
      "eval": "result.get('count', 0) == 2",
      "description": "2 occurrences of 'Q4 2025' in document"
    },
    {
      "command": "headers-footers",
      "eval": "'Revised March 2026' in result.get('footer_text', '')",
      "description": "Footer contains 'Revised March 2026'"
    },
    {
      "command": "check-file-saved",
      "key": "saved",
      "expected": true,
      "description": "File has been saved"
    }
  ],
  "metadata": {
    "complexity": 3,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 3
  }
}
