{
  "id": "zoom_virtual_background_setup",
  "app": "zoom",
  "task": "A baseline Zoom config file exists at /home/user/.config/zoomus.conf. Configure Zoom's virtual background feature so the user's background is blurred and hardware-accelerated, by updating keys across two sections:\n- `[Video]EnableVirtualBackground` = `true`\n- `[Video]VirtualBackgroundType` = `blur`\n- `[Video]BlurStrength` = `50`\n- `[General]EnableHWAccel` = `true`\n\nSave the file in-place at /home/user/.config/zoomus.conf. Do not modify any other keys or sections (in particular, leave `[Video]HDVideo=false` and `[Video]TouchUpMyAppearance=true` untouched).",
  "env": {
    "files": [
      {
        "filename": "zoomus.conf",
        "sandbox_path": "/home/user/.config/zoomus.conf"
      }
    ]
  },
  "verification": [
    {
      "command": "check-config-exists",
      "key": "exists",
      "expected": true,
      "description": "zoomus.conf exists"
    },
    {
      "command": "check-config Video EnableVirtualBackground true",
      "key": "match",
      "expected": true,
      "description": "[Video]EnableVirtualBackground == true"
    },
    {
      "command": "check-config Video VirtualBackgroundType blur",
      "key": "match",
      "expected": true,
      "description": "[Video]VirtualBackgroundType == blur"
    },
    {
      "command": "check-config Video BlurStrength 50",
      "key": "match",
      "expected": true,
      "description": "[Video]BlurStrength == 50"
    },
    {
      "command": "check-config General EnableHWAccel true",
      "key": "match",
      "expected": true,
      "description": "[General]EnableHWAccel == true"
    },
    {
      "command": "check-config Video HDVideo false",
      "key": "match",
      "expected": true,
      "description": "Other [Video] keys untouched"
    },
    {
      "command": "check-config Video TouchUpMyAppearance true",
      "key": "match",
      "expected": true,
      "description": "TouchUpMyAppearance untouched"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
