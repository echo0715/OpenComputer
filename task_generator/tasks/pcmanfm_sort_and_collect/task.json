{
  "id": "pcmanfm_sort_and_collect",
  "app": "pcmanfm",
  "task": "Organize the files in /home/user/Documents/inbox/ by person. Create three directories under /home/user/Documents/organized/ — alice, bob, charlie — and MOVE each person's four files (report, notes, data, summary) from the inbox into their matching directory so each person's directory contains exactly 4 files. Then create /home/user/Documents/organized/index.txt with exactly these three lines:\n- 'alice - 4 files'\n- 'bob - 4 files'\n- 'charlie - 4 files'\n\n/home/user/Documents/inbox/ must be empty after all files are moved.",
  "env": {
    "files": [
      {
        "filename": "alice_report.txt",
        "sandbox_path": "/home/user/Documents/inbox/alice_report.txt"
      },
      {
        "filename": "alice_notes.txt",
        "sandbox_path": "/home/user/Documents/inbox/alice_notes.txt"
      },
      {
        "filename": "alice_data.csv",
        "sandbox_path": "/home/user/Documents/inbox/alice_data.csv"
      },
      {
        "filename": "alice_summary.txt",
        "sandbox_path": "/home/user/Documents/inbox/alice_summary.txt"
      },
      {
        "filename": "bob_report.txt",
        "sandbox_path": "/home/user/Documents/inbox/bob_report.txt"
      },
      {
        "filename": "bob_notes.txt",
        "sandbox_path": "/home/user/Documents/inbox/bob_notes.txt"
      },
      {
        "filename": "bob_data.csv",
        "sandbox_path": "/home/user/Documents/inbox/bob_data.csv"
      },
      {
        "filename": "bob_summary.txt",
        "sandbox_path": "/home/user/Documents/inbox/bob_summary.txt"
      },
      {
        "filename": "charlie_report.txt",
        "sandbox_path": "/home/user/Documents/inbox/charlie_report.txt"
      },
      {
        "filename": "charlie_notes.txt",
        "sandbox_path": "/home/user/Documents/inbox/charlie_notes.txt"
      },
      {
        "filename": "charlie_data.csv",
        "sandbox_path": "/home/user/Documents/inbox/charlie_data.csv"
      },
      {
        "filename": "charlie_summary.txt",
        "sandbox_path": "/home/user/Documents/inbox/charlie_summary.txt"
      }
    ]
  },
  "verification": [
    {
      "command": "check-dir-exists /home/user/Documents/organized/alice",
      "key": "exists",
      "expected": true,
      "description": "alice directory exists"
    },
    {
      "command": "check-dir-exists /home/user/Documents/organized/bob",
      "key": "exists",
      "expected": true,
      "description": "bob directory exists"
    },
    {
      "command": "check-dir-exists /home/user/Documents/organized/charlie",
      "key": "exists",
      "expected": true,
      "description": "charlie directory exists"
    },
    {
      "command": "check-file-count /home/user/Documents/organized/alice 4",
      "key": "count",
      "expected": 4,
      "description": "alice directory has 4 files"
    },
    {
      "command": "check-file-count /home/user/Documents/organized/bob 4",
      "key": "count",
      "expected": 4,
      "description": "bob directory has 4 files"
    },
    {
      "command": "check-file-count /home/user/Documents/organized/charlie 4",
      "key": "count",
      "expected": 4,
      "description": "charlie directory has 4 files"
    },
    {
      "command": "check-file-count /home/user/Documents/inbox 0",
      "key": "count",
      "expected": 0,
      "description": "inbox is empty after moving all files"
    },
    {
      "command": "check-file-contains /home/user/Documents/organized/index.txt alice - 4 files",
      "key": "contains",
      "expected": true,
      "description": "index.txt contains alice entry"
    },
    {
      "command": "check-file-contains /home/user/Documents/organized/index.txt bob - 4 files",
      "key": "contains",
      "expected": true,
      "description": "index.txt contains bob entry"
    },
    {
      "command": "check-file-contains /home/user/Documents/organized/index.txt charlie - 4 files",
      "key": "contains",
      "expected": true,
      "description": "index.txt contains charlie entry"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 4
  }
}
