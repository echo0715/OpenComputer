{
  "id": "eclipse_gap_external_tool_config",
  "app": "eclipse",
  "task": "Eclipse is open with the workspace at /home/user/workspace, which contains 'DemoApp' with `scripts/build.sh`.\n\nCreate an external tool (Program-type) launch configuration named 'BuildScript' (type `org.eclipse.ui.externaltools.ProgramLaunchConfigurationType`) with:\n\n- Location: `/bin/bash`\n- Tool arguments: must reference `scripts/build.sh` (e.g., `${workspace_loc:/DemoApp}/scripts/build.sh`)\n- Working directory: must reference DemoApp (e.g., `${workspace_loc:/DemoApp}`)",
  "env": {
    "files": [
      {
        "filename": "DemoApp/.project",
        "sandbox_path": "/home/user/workspace/DemoApp/.project"
      },
      {
        "filename": "DemoApp/.classpath",
        "sandbox_path": "/home/user/workspace/DemoApp/.classpath"
      },
      {
        "filename": "DemoApp/src/com/example/App.java",
        "sandbox_path": "/home/user/workspace/DemoApp/src/com/example/App.java"
      },
      {
        "filename": "DemoApp/src/com/example/Service.java",
        "sandbox_path": "/home/user/workspace/DemoApp/src/com/example/Service.java"
      },
      {
        "filename": "DemoApp/scripts/build.sh",
        "sandbox_path": "/home/user/workspace/DemoApp/scripts/build.sh"
      }
    ]
  },
  "verification": [
    {
      "command": "check-launch-config /home/user/workspace BuildScript org.eclipse.ui.externaltools.ProgramLaunchConfigurationType",
      "key": "type_matches",
      "expected": true,
      "description": "External tool Program launch type"
    },
    {
      "command": "check-launch-attribute /home/user/workspace BuildScript org.eclipse.ui.externaltools.ATTR_LOCATION /bin/bash",
      "key": "matches",
      "expected": true,
      "description": "Program location = /bin/bash"
    },
    {
      "command": "check-launch-attribute-contains /home/user/workspace BuildScript org.eclipse.ui.externaltools.ATTR_TOOL_ARGUMENTS scripts/build.sh",
      "key": "contains",
      "expected": true,
      "description": "Tool arguments reference scripts/build.sh"
    },
    {
      "command": "check-launch-attribute-contains /home/user/workspace BuildScript org.eclipse.ui.externaltools.ATTR_WORKING_DIRECTORY DemoApp",
      "key": "contains",
      "expected": true,
      "description": "Working directory references DemoApp"
    }
  ],
  "metadata": {
    "complexity": 4,
    "data_generatability": 5,
    "estimated_difficulty": 4
  }
}
