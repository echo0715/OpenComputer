{
  "id": "zoom_enable_hd_video",
  "app": "zoom",
  "task": "A baseline Zoom config file exists at /home/user/.config/zoomus.conf with `[Video]HDVideo=false`.\n\nSet `[Video]HDVideo` to `true` to enable HD video. Save the file in-place at /home/user/.config/zoomus.conf. Do not modify any other keys (leave `[Video]mirrorMyVideo` untouched).",
  "env": {
    "files": [
      {
        "filename": "zoomus.conf",
        "sandbox_path": "/home/user/.config/zoomus.conf"
      }
    ]
  },
  "verification": [
    {
      "command": "check-config-exists",
      "key": "exists",
      "expected": true,
      "description": "zoomus.conf exists"
    },
    {
      "command": "check-config Video HDVideo true",
      "key": "match",
      "expected": true,
      "description": "[Video]HDVideo == true"
    },
    {
      "command": "check-config Video mirrorMyVideo true",
      "key": "match",
      "expected": true,
      "description": "mirrorMyVideo left untouched"
    }
  ],
  "metadata": {
    "complexity": 3,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 3
  }
}
