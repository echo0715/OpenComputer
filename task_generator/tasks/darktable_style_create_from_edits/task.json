{
  "id": "darktable_style_create_from_edits",
  "app": "darktable",
  "task": "Import /home/user/Pictures/scene.png into the darktable library.\n\nEnable the 'exposure' module with raised exposure and enable the 'color balance rgb' module (internally 'colorbalancergb') with adjusted settings. From this image's edits, create a new darktable style named 'my_look' that captures these changes. Apply the tag 'styled' to the image and set its star rating to 3 stars.",
  "env": {
    "files": [
      {
        "filename": "scene.png",
        "sandbox_path": "/home/user/Pictures/scene.png"
      }
    ]
  },
  "verification": [
    {
      "command": "check-image-imported scene.png",
      "key": "imported",
      "expected": true,
      "description": "scene.png imported into darktable library"
    },
    {
      "command": "check-db-has-operation scene.png exposure",
      "key": "has_operation",
      "expected": true,
      "description": "library.db history contains 'exposure' operation"
    },
    {
      "command": "check-db-has-operation scene.png colorbalancergb",
      "key": "has_operation",
      "expected": true,
      "description": "library.db history contains 'colorbalancergb' operation"
    },
    {
      "command": "check-style-exists my_look",
      "key": "exists",
      "expected": true,
      "description": "Style 'my_look' exists in data.db"
    },
    {
      "command": "check-image-tagged-by-filename scene.png styled",
      "key": "tagged",
      "expected": true,
      "description": "scene.png is tagged with 'styled'"
    },
    {
      "command": "check-image-rating-by-filename scene.png 3",
      "key": "matches",
      "expected": true,
      "description": "scene.png rating is 3 stars"
    }
  ],
  "metadata": {
    "complexity": 5,
    "data_generatability": 4,
    "verification_determinism": 5,
    "estimated_difficulty": 5
  }
}
