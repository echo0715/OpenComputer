{
  "id": "zotero_export_two_collection_bibtex_with_publisher",
  "app": "zotero",
  "task": "A pre-seeded Zotero library is at /home/user/Zotero/zotero.sqlite containing 4 items in 'My Library', including the journal article 'A Survey of RL Methods'.\n\nComplete both parts:\n1. Edit 'A Survey of RL Methods' so its DOI is exactly `10.1234/rl-survey-2020` and its Pages field is exactly `1-42`.\n2. Export the entire 'My Library' to BibTeX format at exactly /home/user/Documents/full_library.bib. The exported file must contain exactly 4 BibTeX entries including one whose title contains 'Survey of RL Methods'.\n\nLeave Zotero running.",
  "env": {
    "files": [
      {
        "filename": "zotero.sqlite",
        "sandbox_path": "/home/user/Zotero/zotero.sqlite"
      }
    ]
  },
  "verification": [
    {
      "command": "check-item-field 'Survey of RL Methods' DOI 10.1234/rl-survey-2020",
      "key": "match",
      "expected": true,
      "description": "Survey DOI updated"
    },
    {
      "command": "check-item-field 'Survey of RL Methods' pages 1-42",
      "key": "match",
      "expected": true,
      "description": "Survey pages updated"
    },
    {
      "command": "check-file-exists /home/user/Documents/full_library.bib",
      "key": "exists",
      "expected": true,
      "description": "BibTeX export file exists"
    },
    {
      "command": "check-bibtex-count /home/user/Documents/full_library.bib 4",
      "key": "match",
      "expected": true,
      "description": "BibTeX has 4 entries"
    },
    {
      "command": "check-bibtex-title /home/user/Documents/full_library.bib 'Survey of RL Methods'",
      "key": "contains",
      "expected": true,
      "description": "BibTeX contains survey title"
    }
  ],
  "metadata": {
    "complexity": 5,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 5
  }
}
