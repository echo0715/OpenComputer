{
  "id": "gedit_number_lines_prefix",
  "app": "gedit",
  "task": "/home/user/Documents/tasks.txt currently has 6 unnumbered task descriptions:\n\n```\nPlan project\nGather requirements\nDesign architecture\nImplement features\nWrite tests\nDeploy application\n```\n\nPrefix each line with `<n>. ` (number, period, space) so the file becomes exactly:\n\n```\n1. Plan project\n2. Gather requirements\n3. Design architecture\n4. Implement features\n5. Write tests\n6. Deploy application\n```\n\nThe file must still have exactly 6 lines.",
  "env": {
    "files": [
      {
        "filename": "tasks.txt",
        "sandbox_path": "/home/user/Documents/tasks.txt"
      }
    ]
  },
  "verification": [
    {
      "command": "check-file-exists /home/user/Documents/tasks.txt",
      "key": "exists",
      "expected": true,
      "description": "tasks.txt file exists"
    },
    {
      "command": "check-file-line /home/user/Documents/tasks.txt 1 \"1. Plan project\"",
      "key": "matches",
      "expected": true,
      "description": "Line 1 is '1. Plan project'"
    },
    {
      "command": "check-file-line /home/user/Documents/tasks.txt 2 \"2. Gather requirements\"",
      "key": "matches",
      "expected": true,
      "description": "Line 2 is '2. Gather requirements'"
    },
    {
      "command": "check-file-line /home/user/Documents/tasks.txt 3 \"3. Design architecture\"",
      "key": "matches",
      "expected": true,
      "description": "Line 3 is '3. Design architecture'"
    },
    {
      "command": "check-file-line /home/user/Documents/tasks.txt 4 \"4. Implement features\"",
      "key": "matches",
      "expected": true,
      "description": "Line 4 is '4. Implement features'"
    },
    {
      "command": "check-file-line /home/user/Documents/tasks.txt 5 \"5. Write tests\"",
      "key": "matches",
      "expected": true,
      "description": "Line 5 is '5. Write tests'"
    },
    {
      "command": "check-file-line /home/user/Documents/tasks.txt 6 \"6. Deploy application\"",
      "key": "matches",
      "expected": true,
      "description": "Line 6 is '6. Deploy application'"
    },
    {
      "command": "check-file-line-count /home/user/Documents/tasks.txt 6",
      "key": "matches",
      "expected": true,
      "description": "File still has exactly 6 lines"
    }
  ],
  "metadata": {
    "complexity": 3,
    "data_generatability": 5,
    "verification_determinism": 5,
    "estimated_difficulty": 3
  }
}
